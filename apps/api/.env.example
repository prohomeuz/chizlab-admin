# =============================================================================
# Database
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=chizlab
DATABASE_PASSWORD=chizlab_password
DATABASE_NAME=chizlab_materials
# Set to true ONLY in development; migrations run on start in production
DATABASE_SYNCHRONIZE=false

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# JWT
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Access token TTL (seconds); default 900 = 15 minutes
JWT_ACCESS_EXPIRES_IN=900
# Refresh token TTL (seconds); default 604800 = 7 days
JWT_REFRESH_EXPIRES_IN=604800

# =============================================================================
# Admin PIN
# =============================================================================
# Exactly 8 numeric digits. Stored as bcrypt hash in DB.
ADMIN_PIN=12345678

# =============================================================================
# MinIO / S3
# =============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chizlab-media
# Public URL prefix for uploaded files (no trailing slash)
MINIO_PUBLIC_URL=http://localhost:9000/chizlab-media

# =============================================================================
# Security
# =============================================================================
# Key required in X-API-Key header for all /api/public/* routes
PUBLIC_API_KEY=change_me_public_api_key
# Secret required in X-Internal-Secret header for /internal/ai-result
INTERNAL_CALLBACK_SECRET=change_me_internal_secret

# =============================================================================
# App
# =============================================================================
PORT=3000
NODE_ENV=development
