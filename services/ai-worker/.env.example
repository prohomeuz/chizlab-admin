# =============================================================================
# NestJS internal callback
# =============================================================================
INTERNAL_CALLBACK_URL=http://localhost:3000/internal/ai-result
INTERNAL_PAGE_PREP_CALLBACK_URL=http://localhost:3000/internal/page-prep-result
INTERNAL_CALLBACK_SECRET=change_me_internal_secret

# =============================================================================
# AI provider selection
# =============================================================================
# Options: gemini | openai | claude
AI_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=

# OpenAI (stub — not implemented, will raise NotImplementedError)
OPENAI_API_KEY=

# Anthropic Claude (stub — not implemented, will raise NotImplementedError)
ANTHROPIC_API_KEY=
