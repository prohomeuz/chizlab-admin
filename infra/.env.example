# =============================================================================
# CHIZLAB Materials — Canonical environment variables
# Copy this file to infra/.env and fill in real values.
# NEVER commit infra/.env — it is listed in .gitignore.
# =============================================================================
#
# PRODUCTION CHECKLIST (change all items marked ⚠️ before going live):
#   ⚠️  ADMIN_PIN        — change from default 12345678
#   ⚠️  MINIO_SECRET_KEY — change from default minioadmin123
#   ⚠️  JWT_ACCESS_SECRET / JWT_REFRESH_SECRET — generate random 64-byte hex
#   ⚠️  INTERNAL_CALLBACK_SECRET — generate random hex
#   ⚠️  GEMINI_API_KEY   — REQUIRED: AI worker will not function without this
#   ⚠️  CORS_ORIGINS     — set to your production admin panel domain
#   ⚠️  MINIO_PUBLIC_URL — set to your production domain/CDN
# =============================================================================

# =============================================================================
# PostgreSQL (used by the postgres container and NestJS)
# =============================================================================
POSTGRES_USER=chizlab
POSTGRES_PASSWORD=chizlab_password
POSTGRES_DB=chizlab_materials

# =============================================================================
# Redis
# =============================================================================
# URL form — used by the Python AI worker
REDIS_URL=redis://redis:6379

# =============================================================================
# JWT
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Token TTL in seconds: 900 = 15 min, 604800 = 7 days
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# =============================================================================
# Admin PIN
# =============================================================================
# Exactly 8 numeric digits. Stored as bcrypt hash in DB at first boot.
# ⚠️ CHANGE BEFORE PRODUCTION — default 12345678 is insecure
ADMIN_PIN=12345678

# =============================================================================
# MinIO / S3-compatible object storage
# =============================================================================
MINIO_ACCESS_KEY=minioadmin
# ⚠️ CHANGE BEFORE PRODUCTION — default is publicly known
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=chizlab-media
# Public URL for constructing media links returned to clients.
# Media links are built as `${MINIO_PUBLIC_URL}/<object-key>`.
# Production: use the dedicated media subdomain that maps the bucket to its root,
#   so links look like https://media.chizlab.uz/<uuid>.pdf
#   -> MINIO_PUBLIC_URL=https://media.chizlab.uz
# Local dev (path-style MinIO) keeps the bucket in the path:
MINIO_PUBLIC_URL=http://localhost:9100/chizlab-media

# =============================================================================
# Security
# =============================================================================
# Comma-separated hostnames allowed to call /api/public/* routes
# (checked against the Origin header, falling back to Referer)
PUBLIC_ALLOWED_ORIGINS=chizlab.uz,www.chizlab.uz,api.chizlab.uz
# Required in X-Internal-Secret header for /internal/ai-result
INTERNAL_CALLBACK_SECRET=change_me_internal_secret

# Comma-separated list of allowed CORS origins for the admin panel.
# ⚠️ CHANGE BEFORE PRODUCTION — set to your admin panel domain
# Production example: CORS_ORIGINS=https://admin.chizlab.uz
# Development:        CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# =============================================================================
# Telegram channel notifications
# When a material is published, the API posts it to the channel; edits/
# unpublish/delete keep that post in sync. Leave either value empty to disable.
# The bot must be an ADMIN of the channel.
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Public channel: @channelusername | Private channel: -1001234567890
TELEGRAM_CHANNEL_ID=@your_channel
# Public site base URL for the "Batafsil" link
PUBLIC_SITE_URL=https://chizlab.uz

# =============================================================================
# AI Worker
# =============================================================================
AI_PROVIDER=gemini
# ⚠️ REQUIRED — AI worker crashes on startup without a real key.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Stub keys — only needed if switching providers via AI_PROVIDER env var
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Callback URL the worker uses to report results back to NestJS
# In Docker Compose this is the internal service DNS name — do NOT change
INTERNAL_CALLBACK_URL=http://api:3000/internal/ai-result

# =============================================================================
# App
# =============================================================================
NODE_ENV=production

# Optional: override exposed host ports
API_PORT=3000
ADMIN_PORT=80
