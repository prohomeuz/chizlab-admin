# =============================================================
# CHIZLAB Materials — Environment Variables
# =============================================================
# Copy this file to .env and fill in real values before starting.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This .env.example file is safe to commit — it contains only
# placeholder values, no real secrets.
# =============================================================


# -------------------------------------------------------------
# PostgreSQL
# Used by: api (DATABASE_URL), docker-compose (POSTGRES_*)
# -------------------------------------------------------------

# Full connection string for NestJS / TypeORM
DATABASE_URL=postgresql://chizlab:changeme@localhost:5432/chizlab_db

# Credentials used by the postgres container itself
POSTGRES_USER=chizlab
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chizlab_db


# -------------------------------------------------------------
# Redis
# Used by: api (job queue producer), ai-worker (job queue consumer)
# -------------------------------------------------------------

# Full Redis connection URL
REDIS_URL=redis://localhost:6379


# -------------------------------------------------------------
# MinIO (S3-compatible object storage)
# IMPORTANT: minio_data Docker volume holds all uploaded media.
# Never remove that volume unless you intend to delete all media.
# -------------------------------------------------------------

# Internal endpoint used by api and ai-worker (inside Docker network
# this should be http://minio:9000 — use localhost only for local dev)
MINIO_ENDPOINT=http://localhost:9000

# Root credentials (also passed as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# to the MinIO container via docker-compose)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Bucket that stores all uploaded materials media
MINIO_BUCKET=chizlab-media

# Public base URL used to build download links returned to clients
# In production this would be your CDN or MinIO public domain
MINIO_PUBLIC_URL=http://localhost:9000/chizlab-media


# -------------------------------------------------------------
# JWT (JSON Web Tokens)
# Used by: api (auth module)
# Use a long random string for each secret (e.g. openssl rand -hex 64)
# -------------------------------------------------------------

# Signs short-lived access tokens
JWT_ACCESS_SECRET=change-this-to-a-long-random-secret

# Signs longer-lived refresh tokens (keep separate from access secret)
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

# Access token lifetime (e.g. 15m, 30m)
JWT_ACCESS_EXPIRES=15m

# Refresh token lifetime (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES=7d


# -------------------------------------------------------------
# Admin Authentication
# -------------------------------------------------------------

# 8-digit PIN for the initial admin account seed
# Must be exactly 8 numeric digits
ADMIN_PIN=12345678


# -------------------------------------------------------------
# Public API
# Used by: api — restricts /api/public/* to requests whose Origin
# (or Referer, as fallback) hostname is in this list
# -------------------------------------------------------------

PUBLIC_ALLOWED_ORIGINS=chizlab.uz,www.chizlab.uz,api.chizlab.uz


# -------------------------------------------------------------
# Internal AI Callback
# Used by: api (internal callback endpoint), ai-worker (outgoing requests)
# Never expose the internal callback endpoint publicly.
# -------------------------------------------------------------

# Shared secret sent as X-Internal-Secret header by the ai-worker
# Generate with: openssl rand -hex 32
INTERNAL_CALLBACK_SECRET=change-this-to-a-random-secret

# URL the ai-worker uses to POST results back to the NestJS callback endpoint
# Inside the Docker network use the service name (api); for local dev use localhost
INTERNAL_CALLBACK_URL=http://api:3000/internal/ai-result


# -------------------------------------------------------------
# Telegram channel notifications
# Used by: api (posts/edits/deletes a channel message when a material
# is published, edited, unpublished or deleted).
# Leave TELEGRAM_BOT_TOKEN or TELEGRAM_CHANNEL_ID empty to disable.
# -------------------------------------------------------------

# Bot token from @BotFather. The bot must be an ADMIN of the channel.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Target channel. Public channel: @channelusername
# Private channel: numeric id like -1001234567890
# (to find a private channel's id, post any message in it while the bot is
#  admin, then open https://api.telegram.org/bot<TOKEN>/getUpdates and read
#  result[].channel_post.chat.id)
TELEGRAM_CHANNEL_ID=@your_channel

# Public site base URL used to build the "Batafsil" link in each post
# Final link: {PUBLIC_SITE_URL}/materiallar/{category-slug}/{material-id}
PUBLIC_SITE_URL=https://chizlab.uz


# -------------------------------------------------------------
# AI Provider
# Used by: ai-worker
# AI_PROVIDER selects the active adapter: gemini | openai | claude
# Only the key for the chosen provider needs to be set.
# -------------------------------------------------------------

# Active provider
AI_PROVIDER=gemini

# Google Gemini (default — multimodal: image, video, PDF, audio)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (stub adapter included for future use)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude (stub adapter included for future use)
ANTHROPIC_API_KEY=your-anthropic-api-key-here


# -------------------------------------------------------------
# App Ports (host-side port bindings in docker-compose)
# -------------------------------------------------------------

# NestJS API port
API_PORT=3000

# Admin panel port (nginx serving the React build)
ADMIN_PORT=80

# Node environment (development | production)
NODE_ENV=production
